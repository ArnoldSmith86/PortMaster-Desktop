<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PortMasterDesktop.Views.InputDialog"
        Title="PortMaster Desktop"
        Width="480" SizeToContent="Height"
        Background="#0d0d1a"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="20" Spacing="14">
        <TextBlock x:Name="TitleBlock" FontSize="15" FontWeight="Bold" Foreground="#e8e8f4"
                   TextWrapping="Wrap"/>
        <TextBlock x:Name="MessageBlock" FontSize="12" Foreground="#9090b0"
                   TextWrapping="Wrap"/>
        <TextBox x:Name="InputBox" Background="#1e1e38" Foreground="#e8e8f4"
                 BorderBrush="#2d2d52" BorderThickness="1" CornerRadius="8"
                 Padding="10,8" FontSize="12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Classes="secondary" Click="OnCancel"/>
            <Button Content="OK" Classes="primary" Click="OnOk"/>
        </StackPanel>
    </StackPanel>

    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#6c63ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,7"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#2a2a4a"/>
            <Setter Property="Foreground" Value="#b0b0cc"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="BorderBrush" Value="#2d2d52"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Styles>
</Window>
