<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PortMasterDesktop.Views.MessageBox"
        Background="#1e1e38"
        Width="480" MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="Height">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <TextBlock Grid.Row="0" x:Name="TitleBlock"
                   FontSize="16" FontWeight="Bold" Foreground="#e8e8f4"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>
        <ScrollViewer Grid.Row="1" MaxHeight="400">
            <TextBlock x:Name="BodyBlock"
                       FontSize="13" Foreground="#b0b0cc"
                       TextWrapping="Wrap" Margin="0,0,0,16"/>
        </ScrollViewer>
        <Button Grid.Row="2" Content="OK" HorizontalAlignment="Right"
                Classes="primary" Click="OnOkClicked"/>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#6c63ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,8"/>
        </Style>
    </Window.Styles>
</Window>
